{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendation",
    "reason",
    "must_fix",
    "can_defer",
    "next_step"
  ],
  "properties": {
    "recommendation": {
      "type": "string",
      "enum": ["continue", "fix", "done", "human"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "must_fix": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "can_defer": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    },
    "spot_check_required": {
      "type": "boolean"
    }
  }
}
